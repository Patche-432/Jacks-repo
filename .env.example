# ============================================================================
# .env.example — Fortis multi-agent trading bot
# ============================================================================
#
# Copy this file to .env (in the repo root) and fill in your values.
# The bot loads it automatically at startup via python-dotenv.
#
# Priority: shell environment variables > .env > defaults coded in Python
# So you can always override any setting by exporting the variable in your
# terminal session without editing this file.
#
# IMPORTANT — .env is gitignored. Never commit it with real credentials.
# ============================================================================

# ─── Ollama — Agent 0 (Orchestrator) LLM backend ────────────────────────────
#
# The Orchestrator (Agent 0) talks to a LOCAL Ollama server over HTTP.
# No pip package needed — the code uses Python's stdlib urllib.
#
# Install Ollama (one-time):
#   winget install Ollama.Ollama
#   OR download from https://ollama.com/download/windows
#
# Pull the model and verify (one-time):
#   .\scripts\setup_ollama.ps1
#
# Then run the full preflight:
#   python scripts\preflight.py

# Where the local Ollama HTTP server is listening.
OLLAMA_URL=http://localhost:11434

# Which model the Orchestrator calls. Options by hardware:
#   qwen2.5:3b-instruct   — CPU-friendly default (~4 GB RAM)
#   qwen2.5:7b-instruct   — better reasoning (~8 GB RAM / small GPU)
#   qwen2.5:14b-instruct  — strong reasoning (~14 GB RAM / GPU recommended)
#   llama3.2:3b           — alternative small model
OLLAMA_MODEL=qwen2.5:3b-instruct

# Seconds the Orchestrator waits for one Ollama response before timing out.
# 60s is safe for CPU inference. Reduce to 15-20 if you have a GPU.
AGENT_TIMEOUT_S=60

# Kill-switch for the agent layer.
# Set to: off / none / disabled / 0 / false  → strategy-only, no auto-trade
# Anything else keeps the full agent stack active.
AI_BACKEND=agent

# ─── Dashboard server ────────────────────────────────────────────────────────
# Used by scripts\serve.py (production WSGI launcher).
# Default: loopback only. Change to 0.0.0.0 to expose on LAN.
FORTIS_HOST=127.0.0.1
FORTIS_PORT=5000

# ─── Bot autostart (used when `python ai_pro.py --run` is called directly) ──
# These are also forwarded from the dashboard's Start button if set there.
#
# BOT_AUTOSTART_SYMBOLS=GBPJPY,EURJPY,GBPUSD,EURUSD
# BOT_AUTOSTART_VOLUME=0.50
# BOT_AUTOSTART_POLL_SECS=300
# BOT_AUTOSTART_AUTO_TRADE=1
# BOT_AUTOSTART_USE_AI=1
# BOT_AUTOSTART_ATR_MULT=1.5
# BOT_AUTOSTART_SL_MULT=2.5
# BOT_AUTOSTART_TP_MULT=4.5

# ─── MT5 broker credentials ──────────────────────────────────────────────────
# These are read by core/mt5_config.py. The preferred way to set credentials
# is through the dashboard's "Connect MT5" form, which encrypts them to
# core/mt5_credentials_config.json (gitignored).
#
# Uncomment and fill in if you want to set them via environment instead:
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=
# MT5_PATH=
