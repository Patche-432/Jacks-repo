{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Fortis Dashboard (serve.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\scripts\\serve.py",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Fortis Dashboard (flask dev)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\ai_pro.py",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "FLASK_ENV": "development"
            }
        },
        {
            "name": "Run Tests (pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": ["-v"],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Preflight Check",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\scripts\\preflight.py",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
